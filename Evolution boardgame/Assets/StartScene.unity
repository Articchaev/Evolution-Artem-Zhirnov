--- !u!1001 &1635371594
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1046004491}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Running
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0411\u044B\u0441\u0442\u0440\u043E\u0435.
        \u041A\u043E\u0433\u0434\u0430 \u0432\u0430\u0448\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 
        \u0441 \u044D\u0442\u0438\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C,
        \u0431\u0440\u043E\u0441\u044C\u0442\u0435\r\n\u043A\u0443\u0431\u0438\u043A.
        \u0415\u0441\u043B\u0438 \u0432\u044B\u043F\u0430\u043B\u043E 4, 5 \u0438\u043B\u0438
        6 \u2013 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043D\u0435 \u0441\u044C\u0435\u0434\u0435\u043D\u043E.
        \u0410\u0442\u0430\u043A\u043E\u0432\u0430\u0432\u0448\u0438\u0439 \u0445\u0438\u0449\u043D\u0438\u043A
        \u0432 \u044D\u0442\u043E\u0442\r\n\u0445\u043E\u0434 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C \u0434\u0440\u0443\u0433\u043E\u0435
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435.\r\n\u0432\u044B \u043D\u0435
        \u043C\u043E\u0436\u0435\u0442\u0435 \u043E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u0430
        \u043E\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0430
        \u044D\u0442\u043E\u0433\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
        \u0434\u0430\u0436\u0435 \u0432 \u0442\u043E\u043C \u0441\u043B\u0443\x1C\r\u0447\u0430\u0435,
        \u0435\u0441\u043B\u0438 \u0430\u0442\u0430\u043A\u0443\u0435\u0442\u0435
        \u0441\u0432\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u0441\u0432\u043E\u0438\u043C \u0436\u0435 \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C."
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_fontSize
