PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1286015503}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Scavenger
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043F\u0430\u0434\u0430\u043B\u044C\u0449\u0438\u043A.
        \u041A\u043E\u0433\u0434\u0430 \u0441\u044A\u0435\u0434\u0435\u043D\u043E
        \u0434\u0440\u0443\u0433\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435,
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u0441 \u044D\u0442\u0438\u043C
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
        \u0441\u0438\u043D\u044E\u044E \u0435\u0434\u0443. \u0421\u0438\u043D\u044E\u044E
        \u0435\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
        \u043E\u0434\u043D\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u043D\u0430 \u0441\u0442\u043E\u043B\u0435, \u043D\u0430\u0447\u0438\u043D\u0430\u044F
        \u0441 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430,
        \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
        \u0445\u0438\u0449\u043D\u0438\u043A \u0438 \u0434\u0430\u043B\u0435\u0435
        \u043F\u043E \u0447\u0430\u0441\u043E\u0432\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u043A\u0435. 
        \u042D\u0442\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043D\u0435\u043B\u044C\u0437\u044F
        \u0441\u044B\u0433\u0440\u0430\u0442\u044C \u043D\u0430 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 
        \u0441\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \xAB\u0425\u0438\u0449\u043D\u0438\u043A\xBB,
        \u0438 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442.\r"
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
