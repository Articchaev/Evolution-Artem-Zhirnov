      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043F\u0430\u0440\u0430\u0437\u0438\u0442.
        \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0441\u044B\u0433\u0440\u0430\u043D\u043E
        \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430.\r
        \u041D\u0430 \u043E\u0434\u043D\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u043C\u043E\u0436\u043D\u043E \u0441\u044B\u0433\u0440\u0430\u0442\u044C
        \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u043D\u043E\u0433\u043E
        \u043F\u0430\u0440\u0430\u0437\u0438\u0442\u0430. \u043F\u0430\u0440\u0430\u0437\u0438\u0442\u0430\r
        \u043C\u043E\u0436\u043D\u043E \u043E\u0442\u0431\u0440\u043E\u0441\u0438\u0442\u044C
        \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
        \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043D\u0438\u0435
        \u0445\u0432\u043E\u0441\u0442\u0430."
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
