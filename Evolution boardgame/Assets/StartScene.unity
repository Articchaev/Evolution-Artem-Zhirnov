    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Poisonous
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u042F\u0434\u043E\u0432\u0438\u0442\u043E\u0435. \u0425\u0438\u0449\u043D\u0438\u043A,
        \u0441\u044A\u0435\u0432\u0448\u0438\u0439 \u044D\u0442\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435,
        \u0432 \u0444\u0430\u0437\u0443 \u0432\u044B\u043C\u0438\u0440\u0430\u043D\u0438\u044F
        \u0442\u0435\u043A\u0443\u0449\u0435\u0433\u043E \u0445\u043E\u0434\u0430
        \u043F\u043E\u0433\u0438\u0431\u0430\u0435\u0442. \u0415\u0441\u043B\u0438
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u0441 \u044D\u0442\u0438\u043C
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0431\u044B\u043B\u043E
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C
        \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u043E
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043D\u0438\u0435
        \u0445\u0432\u043E\u0441\u0442\u0430, \u0442\u043E \u0445\u0438\u0449\u043D\u0438\u043A
        \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u043E\u0434\u043D\u0443\u0441\u0438\u043D\u044E\u044E
        \u0444\u0438\u0448\u043A\u0443 \u0435\u0434\u044B \u0438 \u043D\u0435 \u0443\u043C\u0438\u0440\u0430\u0435\u0442. "
      objectReference: {fileID: 0}
