--- !u!1001 &1702967221
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1286015503}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Symboisis
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0438\u043C\u0431\u0438\u043E\u0437. \u0421\u044B\u0433\u0440\u0430\u0442\u044C
        \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u043D\u0430 \u043F\u0430\u0440\u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445.
        \u041E\u0434\u043D\u043E \u0438\u0437 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
        \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043A\u0430\u043A\r\n\xAB\u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442\xBB.
        \u0414\u0440\u0443\u0433\u043E\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
        \u0431\u044B\u0442\u044C \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E
        \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C, \u043F\u043E\u043A\u0430
        \u0436\u0438\u0432 \xAB\u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442\xBB,
        \u043D\u043E \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
        \u0444\u0438\u0448\u043A\u0438 \u0435\u0434\u044B, \u0442\u043E\u043B\u044C\u043A\u043E
        \u0435\u0441\u043B\u0438 \xAB\u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442\xBB
        \u0443\u0436\u0435 \u043D\u0430\u043A\u043E\u0440\u043C\u043B\u0435\u043D."
      objectReference: {fileID: 0}
