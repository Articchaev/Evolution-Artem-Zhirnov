PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1286015503}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Mimicry
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u041C\u0438\u043C\u0438\u043A\u0440\u0438\u044F. \u041A\u043E\u0433\u0434\u0430
        \u044D\u0442\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E
        \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C, \u0432\u043B\u0430\u0434\u0435\u043B\u0435\u0446
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E \u0434\u043E\u043B\u0436\u0435\u043D
        \u043F\u0435\u0440\u0435\u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C
        \u0430\u0442\u0430\u043A\u0443 \u0445\u0438\u0449\u043D\u0438\u043A\u0430
        \u043D\u0430 \u0434\u0440\u0443\u0433\u043E\u0435 \u0441\u0432\u043E\u0435
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0435
        \u044D\u0442\u043E\u0442 \u0445\u0438\u0449\u043D\u0438\u043A \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C.\r \n\u042D\u0442\u043E
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043C\u043E\u0436\u043D\u043E
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u0438\u043D \u0440\u0430\u0437
        \u0432 \u0445\u043E\u0434, \u0442\u043E \u0435\u0441\u0442\u044C \u0437\u0430
        \u0445\u043E\u0434 \u043C\u043E\u0436\u043D\u043E \u043F\u0435\u0440\u0435\u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C
        \u0430\u0442\u0430\u043A\u0443 \u0445\u0438\u0449\u043D\u0438\u043A\u0430.
        \u0415\u0441\u043B\u0438 \u0443 \u0438\u0433\u0440\u043E\u043A\u0430 \u043D\u0435\u0442
        \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E,
        \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u044D\u0442\u043E\u0442 \u0445\u0438\u0449\u043D\u0438\u043A
        \u043C\u043E\u0433 \u0431\u044B \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C
        (\u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438
        \u043E\u0442 \u0438\u043C\u0435\u044E\u0449\u0438\u0445\u0441\u044F \u0443
        \u043D\u0435\u0433\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432), \u043C\u0438\u043C\u0438\u043A\u0440\u0438\u044F
        \u043D\u0435 \u0441\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442"
      objectReference: {fileID: 0}
