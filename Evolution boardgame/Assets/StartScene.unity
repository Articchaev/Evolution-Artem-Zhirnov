    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043F\u0438\u0440\u0430\u0442\u0441\u0442\u0432\u043E.
        \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u044D\u0442\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0432
        \u0441\u0432\u043E\u044E \u0444\u0430\u0437\u0443 \u043F\u0438\u0442\u0430\u043D\u0438\u044F.
        \u041F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0441\u0438\u043D\u044E\u044E
        \u0435\u0434\u0443,\r \u0437\u0430\u0431\u0440\u0430\u0432 \u043E\u0434\u043D\u0443
        \u0444\u0438\u0448\u043A\u0443 \u043A\u0440\u0430\u0441\u043D\u043E\u0439
        \u0435\u0434\u044B \u0438\u043B\u0438 \u0441\u0438\u043D\u0435\u0439 \u0443
        \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E
        \u043D\u0430 \u0441\u0442\u043E\u043B\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
        \u0435\u0449\u0435 \u043D\u0435 \u043D\u0430\u043A\u043E\u0440\u043C\u043B\u0435\u043D\u043E.
        \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043C\u043E\u0436\u0435\u0442
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u044D\u0442\u043E \u0441\u0432\u043E\u0439\x17\r\u0441\u0442\u0432\u043E
        \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u0438\u043D \u0440\u0430\u0437
        \u0437\u0430 \u0445\u043E\u0434.\r \u041F\u0438\u0440\u0430\u0442\u0441\u0442\u0432\u043E
        \u043C\u043E\u0436\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u0441\u043E \u0432\u0437\u044F\u0442\u0438\u0435\u043C \u043A\u0440\u0430\u0441\u043D\u043E\u0439
        \u0444\u0438\u0448\x1C\r\u043A\u0438 \u0435\u0434\u044B \u0438\u0437 \u043A\u043E\u0440\u043C\u043E\u0432\u043E\u0439
        \u0431\u0430\u0437\u044B \u0438\u043B\u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\r\n\u0445\u0438\u0449\u043D\u0438\u043A
        \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u043C \u0438\u0433\u0440\u043E\u043A\u0430. "
      objectReference: {fileID: 0}
