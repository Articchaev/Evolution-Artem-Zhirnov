    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435.
        \u0421\u044B\u0433\u0440\u0430\u0442\u044C \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u043D\u0430 \u043F\u0430\u0440\u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445.
        \u041A\u043E\u0433\u0434\u0430 \u043E\u0434\u043D\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0435\u0434\u0443 \u0438\u0437
        \u043A\u043E\u0440\u043C\u043E\u0432\u043E\u0439 \u0431\u0430\u0437\u044B,
        \u0434\u0440\u0443\u0433\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0435\u0434\u0443 \u0432\u043D\u0435
        \u043E\u0447\u0435\u0440\u0435\u0434\u0438."
