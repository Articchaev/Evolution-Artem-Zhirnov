--- !u!1001 &1880818462
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1046004491}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Grazing
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0422\u043E\u043F\u043E\u0442\u0443\u043D. \u041C\u043E\u0436\u043D\u043E
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u0432 \u043A\u0430\u0436\u0434\u0443\u044E \u0441\u0432\u043E\u044E \u0444\u0430\u0437\u0443
        \u043F\u0438\u0442\u0430\u043D\u0438\u044F \u2013 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C\r
        \u043E\u0434\u043D\u0443 \u0444\u0438\u0448\u043A\u0443 \u043A\u0440\u0430\u0441\u043D\u043E\u0439
        \u0435\u0434\u044B \u0438\u0437 \u043A\u043E\u0440\u043C\u043E\u0432\u043E\u0439
        \u0431\u0430\u0437\u044B.\r \u0415\u0441\u043B\u0438 \u0443 \u0432\u0430\u0441
        \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
        \u0441\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0422\u041E\u041F\u041E\u0422\u0423\u041D,
        \u0442\u043E \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0432\r \u0441\u0432\u043E\u044E
        \u0444\u0430\u0437\u0443 \u043F\u0438\u0442\u0430\u043D\u0438\u044F \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u0438\u0445 \u0432\u0441\u0435 \u0438 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C
        \u0441\u043E\u043E\u0442\x1C\r\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0435
        \u0447\u0438\u0441\u043B\u043E \u043A\u0440\u0430\u0441\u043D\u044B\u0445
        \u0444\u0438\u0448\u0435\u043A \u0435\u0434\u044B \u0438\u0437 \u043A\u043E\u0440\u043C\u043E\u0432\u043E\u0439
        \u0431\u0430\u0437\u044B. "
      objectReference: {fileID: 0}
