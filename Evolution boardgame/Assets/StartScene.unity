    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0432\u043E\u0434\u043E\u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0435\u0435.
        \u0416\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043C\u043E\u0436\u0435\u0442
        \u0431\u044B\u0442\u044C \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E
        \u0442\u043E\u043B\u044C\u043A\u043E \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C,
        \u0438\u043C\u0435\u044E\u0449\u0438\u043C\r\n\u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
        \u0432\u043E\u0434\u043E\u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0435\u0435.
        \u0445\u0438\u0449\u043D\u0438\u043A \u0441\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
