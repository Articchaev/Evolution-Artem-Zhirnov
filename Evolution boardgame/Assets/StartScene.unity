--- !u!1001 &1514489938
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1046004491}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Tail Loss
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u041E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043D\u0438\u0435
        \u0445\u0432\u043E\u0441\u0442\u0430. \u041A\u043E\u0433\u0434\u0430 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
        \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C,
        \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u0442\u044C \u0432 \u0441\u0431\u0440\u043E\u0441\r
        \u043A\u0430\u0440\u0442\u0443 \u044D\u0442\u043E\u0433\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E
        \u0438\u043B\u0438 \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0438\u043C\u0435\u044E\u0449\u0435\u0433\u043E\u0441\u044F
        \u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430. 
        \u0416\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
        \u0432 \u0436\u0438\u0432\u044B\u0445.\r \u0425\u0438\u0449\u043D\u0438\u043A
        \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
        \u043E\u0434\u043D\u0443 \u0441\u0438\u043D\u0438\u044E \u0435\u0434\u0443.\r\n\u0421
        \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u044D\u0442\u043E\u0433\u043E
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043C\u043E\u0436\u043D\u043E
        \u043E\u0442\u0431\u0440\u043E\u0441\u0438\u0442\u044C \u043B\u044E\u0431\u043E\u0435
        \u0434\u0440\u0443\u0433\u043E\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
        (\u0435\u0441\x1C\r\u043B\u0438 \u0432 \u0442\u0435\u043A\u0441\u0442\u0435
        \u043A\u0430\u0440\u0442\u044B \u043D\u0435 \u0443\u043A\u0430\u0437\u0430\u043D\u043E
        \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0435),
        \u0432\u043A\u043B\u0443\u0447\u0430\u0430 \u043F\u0430\u0440\u043D\u044B\u0435
        \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\r \u0438 \u043F\u0430\u0440\u0430\u0437\u0438\u0442\u0430."
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_fontSize
