--- !u!1001 &1317809766
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1046004491}
    m_Modifications:
    - target: {fileID: 467457787838609812, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_Name
      value: Cooperation
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_text
      value: "\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E.
        \u0421\u044B\u0433\u0440\u0430\u0442\u044C \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
        \u043D\u0430 \u043F\u0430\u0440\u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445.
        \u041A\u043E\u0433\u0434\u0430 \u043E\u0434\u043D\u043E \u043F\u043E\x17\r\u043B\u0443\u0447\u0430\u0435\u0442
        \u0444\u0438\u0448\u043A\u0443 \u0435\u0434\u044B \u2013 \u0432\u0442\u043E\u0440\u043E\u0435
        \u0441\u0440\u0430\u0437\u0443 \u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
        \u043E\u0434\u043D\u0443 \u0441\u0438\u043D\u044E\u044E \u0444\u0438\u0448\u043A\u0443
        \u0435\u0434\u044B. \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C
        \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0438
        \u0438\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
        \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445, \u0441\u043E\u0435\x1C\r\u0434\u0438\u043D\u0435\u043D\u043D\u044B\u0445
        \u043A\u0430\u0440\u0442\u0430\u043C\u0438 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
        \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435,
        \u043D\u043E \u0432 \u043A\u0430\u0436\u0434\u044B\u0439 \u0440\u0430\x1C\r\u0443\u043D\u0434
        \u0444\u0430\u0437\u044B \u043F\u0438\u0442\u0430\u043D\u0438\u044F \u043A\u0430\u0436\u0434\u043E\u0435
        \u0442\u0430\u043A\u043E\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
        \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
        \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u0438\u043D \u0440\u0430\u0437."
      objectReference: {fileID: 0}
    - target: {fileID: 704006866766511653, guid: b2bac2cb7f554b241949c0de0a5a46a7, type: 3}
      propertyPath: m_fontSize
