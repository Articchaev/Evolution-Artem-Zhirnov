  EnglishName: SCAVENGER
  RussianName: "\u041F\u0410\u0414\u0410\u041B\u042C\u0429\u0418\u041A"
  Description: "\u0416\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u0441\u0438\u043D\u044E\u044E \u0435\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u0441\u044A\u0435\u0434\u0435\u043D\u043E \u0434\u0440\u0443\u0433\u043E\u0435
    \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435. \u0421\u0438\u043D\u044E\u044E
    \u0435\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u0438\u043D \u041F\u0410\u0414\u0410\u041B\u042C\u0429\u0418\u041A
    \u0432 \u0438\u0433\u0440\u0435, \u043D\u0430\u0447\u0438\u043D\u0430\u044F \u0441
    \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430
    \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0432\u0448\u0435\u0433\u043E \u0445\u0438\u0449\u043D\u0438\u043A\u0430,
    \u0438 \u0434\u0430\u043B\u0435\u0435 \u043F\u043E \u0447\u0430\u0441\u043E\u0432\u043E\u0439
    \u0441\u0442\u0440\u0435\u043B\u043A\u0435. \u041D\u0435\u043B\u044C\u0437\u044F
    \u0441\u044B\u0433\u0440\u0430\u0442\u044C \u043D\u0430 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E
    \u0441\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0425\u0418\u0429\u041D\u0418\u041A
    \u0438 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442."
