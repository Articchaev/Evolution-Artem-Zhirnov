  EnglishName: SYMBIOSIS
  RussianName: "\u0421\u0418\u041C\u0411\u0418\u041E\u0417"
  Description: "\u0421\u044B\u0433\u0440\u0430\u0442\u044C \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043D\u0430 \u043F\u0430\u0440\u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445.
    \u041E\u0434\u043D\u043E \u0438\u0437 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043A\u0430\u043A
    \u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442. \u0414\u0440\u0443\u0433\u043E\u0435
    \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u043E
    \u0445\u0438\u0449\u043D\u0438\u043A\u043E\u043C, \u043F\u043E\u043A\u0430 \u0436\u0438\u0432
    \u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442, \u043D\u043E \u043C\u043E\u0436\u0435\u0442
    \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u0435\u0434\u0443, \u0442\u043E\u043B\u044C\u043A\u043E
    \u0435\u0441\u043B\u0438 \u0441\u0438\u043C\u0431\u0438\u043E\u043D\u0442 \u0443\u0436\u0435
    \u041D\u0410\u041A\u041E\u0420\u041C\u041B\u0415\u041D."
  BackgroundColor: {r: 0.9490197, g: 0.9960785, b: 0.9176471, a: 1}
